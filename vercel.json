{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/ssr.mjs": {
      "runtime": "@vercel/node@5.1.14",
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/api/ssr" }
  ]
}
